---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="关于" description="关于墨笺与写作者。">
  <section class="about page-shell">
    <aside aria-hidden="true">一方小笺<br />几笔闲墨</aside>
    <div class="about-content">
      <p class="lead page-kicker">关于墨笺</p>
      <h1 class="page-display-title">在喧闹之外，留一页安静。</h1>
      <div class="copy">
        <p>
          墨笺是一处记录生活的小站。写走过的路、读过的书，也写窗前的一场雨和寻常的一顿饭。
        </p>
        <p>
          这里不追逐更新频率，只希望多年以后再翻开时，还能想起当时的光线、气味与心情。
        </p>
        <blockquote>愿每一次落笔，都能为流逝的日子留下微光。</blockquote>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about {
    position: relative;
    display: grid;
    min-height: 65vh;
    grid-template-columns: minmax(4rem, 10rem) minmax(0, 44rem);
    justify-content: center;
    gap: clamp(2rem, 8vw, 7rem);
    padding-top: clamp(5rem, 11vw, 9rem);
  }

  .about::after {
    position: absolute;
    z-index: -1;
    top: 3rem;
    right: 8%;
    width: min(46vw, 31rem);
    aspect-ratio: 1;
    border: 1px solid rgb(83 79 70 / 10%);
    border-radius: 50%;
    content: '';
  }

  :global(html[data-theme='night']) .about::after {
    border-color: rgb(233 226 208 / 9%);
  }

  aside {
    justify-self: end;
    padding-top: 0.5rem;
    color: var(--moss);
    font-family: var(--serif);
    font-size: 1.05rem;
    letter-spacing: 0.28em;
    line-height: 2;
    writing-mode: vertical-rl;
  }

  .lead {
    justify-content: flex-start;
  }

  .lead::after {
    display: none;
  }

  .page-display-title {
    max-width: 10em;
    letter-spacing: 0.1em;
    line-height: 1.45;
  }

  .copy {
    margin-top: 3rem;
    padding: clamp(1.8rem, 4vw, 3rem);
    border-block: 1px solid var(--line-strong);
    color: var(--ink-soft);
    background:
      repeating-linear-gradient(180deg, transparent 0 2.08em, rgb(83 79 70 / 5%) 2.08em calc(2.08em + 1px)),
      rgb(251 249 243 / 28%);
    font-family: var(--serif);
    font-size: 1.05rem;
    line-height: 2;
    letter-spacing: 0.06em;
  }

  :global(html[data-theme='night']) .copy {
    background:
      repeating-linear-gradient(180deg, transparent 0 2.08em, rgb(233 226 208 / 6%) 2.08em calc(2.08em + 1px)),
      rgb(233 226 208 / 5%);
  }

  blockquote {
    margin: 2.5rem 0 0;
    padding: 1.5rem 0 1.5rem 1.5rem;
    border-left: 2px solid var(--cinnabar);
    color: var(--ink);
  }

  @media (max-width: 640px) {
    .about {
      grid-template-columns: 1fr;
    }

    aside {
      display: none;
    }
  }
</style>
