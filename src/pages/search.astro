---
import BaseLayout from '../layouts/BaseLayout.astro';

const BASE = import.meta.env.BASE_URL;
---

<BaseLayout title="寻墨" description="检索墨笺全部文字">
  <section class="search-page page-shell" data-pagefind-ignore>
    <header class="search-header">
      <p class="page-kicker" data-font-role="hand">SEARCH</p>
      <h1 class="page-display-title" data-font-role="cal">寻墨</h1>
      <p class="search-note">旧稿新札，皆可按字索骥。</p>
    </header>
    <div id="search" class="search-box"></div>
  </section>

  <link href={`${BASE}pagefind/pagefind-ui.css`} rel="stylesheet" />
  <script is:inline src={`${BASE}pagefind/pagefind-ui.js`}></script>
  <!-- PagefindUI 初始化在 BaseLayout 持久脚本中（含 Swup 回退重放） -->
</BaseLayout>

<style>
  .search-page {
    padding-top: clamp(4rem, 9vw, 8rem);
    min-height: 60vh;
  }

  .search-header {
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .page-display-title {
    font-size: clamp(2.2rem, 6vw, 3.6rem);
    letter-spacing: 0.14em;
  }

  .search-note {
    margin-top: 1rem;
    color: var(--ink-soft);
    letter-spacing: 0.1em;
  }

  .search-box {
    width: min(100%, 44rem);
    margin-inline: auto;
  }

  /* Pagefind 默认 UI 调色对齐墨色主题 */
  .search-box {
    --pagefind-ui-primary: var(--ink);
    --pagefind-ui-text: var(--ink-soft);
    --pagefind-ui-background: rgb(251 249 243 / 80%);
    --pagefind-ui-border: var(--line-strong);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 2px;
    --pagefind-ui-font: var(--serif);
  }

  :global(html[data-theme='night']) .search-box {
    --pagefind-ui-background: rgb(33 34 29 / 85%);
  }
</style>
