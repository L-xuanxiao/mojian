<BaseLayout title="墨笺" description="墨笺，一处记录日常、山川、旧书与生活片段的个人博客。">
  <div id="top">
    <section class="hero" aria-labelledby="hero-title">
      <div class="shell hero-grid">
        <div class="hero-content">
          <p class="hero-eyebrow">一方墨笺 · 记于人间</p>
          <h1 class="hero-title" id="hero-title">墨笺有余闲<span class="accent-dot">。</span></h1>
          <p class="hero-subtitle">写日常，也写山川与旧书</p>
          <div class="hero-intro">
            这里收拢寻常日子里的微光。<br />
            也留下山川、旧书与缓慢生长的心事。
          </div>
          <div class="hero-actions" aria-label="页面入口">
            <a class="action-primary" href="#articles">阅览文章</a>
            <a class="action-secondary" href="#about">关于此间</a>
          </div>
        </div>

        <div class="hero-side">
          <div class="hero-vertical-copy" aria-hidden="true">风来疏竹　雨过远山</div>
          <aside class="hero-note" aria-label="最新文章">
            <div class="hero-note-head">
              <strong>新札</strong>
              <time datetime={latestPost.data.pubDate.toISOString()}>{formatDate(latestPost.data.pubDate)}</time>
            </div>
            <a class="hero-note-post" href={`${BASE}posts/${latestPost.id}/`}>{latestPost.data.title}</a>
            <p class="hero-note-meta">{latestPost.data.category} · 新卷初展</p>
          </aside>
        </div>
      </div>

      <div class="hero-landscape" aria-hidden="true">
        <Image
          src={inkMountains}
          alt=""
          widths={[960, 1280, 1672]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="scroll-hint" aria-hidden="true">入卷</div>
    </section>

    <div class="home-layout">
    <section class="section study-index" aria-labelledby="study-title">
      <div class="shell study-grid">
        <div class="study-intro reveal">
          <div>
            <p class="section-kicker">THE STUDY INDEX</p>
            <h2 class="study-title" id="study-title">书斋目录</h2>
            <p>把日常与见闻，按四条线索慢慢归置。</p>
          </div>
          <div class="study-mini-painting" aria-hidden="true">
            <svg viewBox="0 0 360 190" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <filter id="miniSoft"><feGaussianBlur stdDeviation="1.2" /></filter>
              </defs>
              <circle cx="286" cy="50" r="20" fill="#a44434" fill-opacity=".12" />
              <path d="M0 140C63 120 87 86 138 96C184 105 196 137 241 125C281 115 312 86 360 82V190H0Z" fill="#586258" fill-opacity=".09" filter="url(#miniSoft)" />
              <path d="M0 164C65 145 109 158 159 137C215 113 255 151 306 141C328 137 344 128 360 119V190H0Z" fill="#303631" fill-opacity=".1" />
              <path d="M259 128l5-28 4 28zm10 1 4-22 3 22z" fill="#303631" fill-opacity=".2" />
              <path d="M46 158c36-12 63-13 96-5" fill="none" stroke="#303631" stroke-opacity=".18" />
            </svg>
          </div>
        </div>

        <nav class="index-list reveal" aria-label="内容分类">
          {siteConfig.categories.map((cat) => (
            <a class="index-item" href={`${BASE}category/${cat.slug}/`}>
              <span class="index-number">{cat.number}</span>
              <span class="index-name">{cat.key}</span>
              <span class="index-desc">{cat.description}</span>
              <span class="index-count">{String(categoryCounts.get(cat.key) ?? 0).padStart(2, '0')} 篇</span>
            </a>
          ))}
        </nav>
      </div>
      <svg class="brush-divider" viewBox="0 0 960 42" preserveAspectRatio="none" aria-hidden="true">
        <path d="M10 23C132 19 228 26 346 21C470 15 592 28 726 20C814 15 888 20 950 17" fill="none" stroke="#485149" stroke-width="4" stroke-linecap="round" opacity=".42" />
        <path d="M75 27C222 25 344 31 486 25C620 20 733 27 861 23" fill="none" stroke="#485149" stroke-width="1" opacity=".35" />
      </svg>
    </section>

    <section class="section latest" id="articles" aria-labelledby="latest-title">
      <div class="shell">
        <div class="section-heading reveal">
          <div>
            <p class="section-kicker">RECENT NOTES</p>
            <h2 class="section-title" id="latest-title">近来所记</h2>
          </div>
          <p class="section-note">新札三卷，横陈案上。行旅、日常与旧书各成一卷，也把远山与墨痕留在纸面。</p>
        </div>

        <div class="scroll-list" id="archive">
          {recentPosts.map((post, index) => (
            <ScrollPostCard post={post} index={index} />
          ))}
        </div>
        <div class="all-posts reveal">
          <a href={`${BASE}archive/`}>查看全部文章</a>
        </div>
      </div>
    </section>

    <section class="section desk" aria-labelledby="desk-title">
      <div class="shell">
        <div class="section-heading reveal">
          <div>
            <p class="section-kicker">ON THE DESK</p>
            <h2 class="section-title" id="desk-title">案头近况</h2>
          </div>
          <p class="section-note">不只保存已经写完的文章，也留下正在发生的过程。墨色稍深，像夜里案上的一盏灯。</p>
        </div>

        <div class="desk-grid">
          <article class="now-panel reveal">
            <div class="panel-mark" aria-hidden="true">今</div>
            <div class="now-head">
              <span>此刻</span>
              <time datetime="2026-07-15">2026.07.15</time>
            </div>
            <div class="now-list">
              <div class="now-row">
                <span class="now-label">正在做</span>
                <strong>继续打磨墨笺的视觉与内容</strong>
                <span class="now-state">进行中</span>
              </div>
              <div class="now-row">
                <span class="now-label">正在读</span>
                <strong>山川、旧书与日常写作的零散笔记</strong>
                <span class="now-state">缓慢读</span>
              </div>
              <div class="now-row">
                <span class="now-label">正在学</span>
                <strong>用更少的元素，建立更稳定的页面秩序</strong>
                <span class="now-state">持续中</span>
              </div>
            </div>
          </article>

          <article class="fragment-panel reveal">
            <div class="fragment-art" aria-hidden="true">
              <svg viewBox="0 0 540 310" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <filter id="deskSoft"><feGaussianBlur stdDeviation="3" /></filter>
                  <linearGradient id="deskMist" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0" stop-color="#eef0e9" stop-opacity=".05" />
                    <stop offset="1" stop-color="#eef0e9" stop-opacity=".2" />
                  </linearGradient>
                </defs>
                <circle cx="402" cy="74" r="34" fill="#bd6756" fill-opacity=".24" />
                <path d="M0 205C82 165 144 182 211 135C276 91 326 130 377 159C427 187 471 159 540 119V310H0Z" fill="url(#deskMist)" filter="url(#deskSoft)" />
                <path d="M0 252C92 215 164 236 233 198C302 161 356 206 410 226C452 241 497 223 540 202V310H0Z" fill="#eef0e9" fill-opacity=".075" />
                <path d="M76 260C142 234 199 242 256 220C326 193 378 219 440 241C476 253 508 247 540 234" fill="none" stroke="#eef0e9" stroke-opacity=".17" />
                <path d="M92 202V72M92 72H320M320 72V205" fill="none" stroke="#eef0e9" stroke-opacity=".2" stroke-width="2" />
                <path d="M207 72V202" fill="none" stroke="#eef0e9" stroke-opacity=".12" />
                <path d="M430 238l7-38 6 38zm12 1 5-29 5 29z" fill="#eef0e9" fill-opacity=".16" />
              </svg>
            </div>
            <div class="fragment-copy">
              <p class="fragment-label">一页小记</p>
              <blockquote>写作并不总是为了给出答案。很多时候，它只是把走过的路重新照亮。</blockquote>
              <p class="fragment-source">—— 记于墨笺之间</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="section about" id="about" aria-labelledby="about-title">
      <div class="shell about-grid">
        <div class="about-copy reveal">
          <p class="section-kicker">ABOUT THIS PLACE</p>
          <h2 class="section-title" id="about-title">关于此间</h2>
          <div class="about-text">
            <p>我喜欢记录日常，也喜欢山川与旧书。</p>
            <p>这个网站会保存沿途所见、读书所得，以及一些没有明确分类的想法。</p>
