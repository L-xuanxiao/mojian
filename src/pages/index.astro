        padding: 126px 0 82px;
      }

      .hero-grid {
        grid-template-columns: 1fr;
      }

      .hero-content {
        max-width: 680px;
      }

      .hero-side {
        display: none;
      }

      .hero-vertical-copy {
        display: none;
      }

      .hero-note {
        width: min(100%, 430px);
