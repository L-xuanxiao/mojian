---
import { Image } from "astro:assets";
import inkMountains from "../assets/ink-mountains.png";
import BaseLayout from "../layouts/BaseLayout.astro";

const BASE = import.meta.env.BASE_URL;
---

<style>

    .section {
      position: relative;
      scroll-margin-top: 76px;
      padding: clamp(92px, 10vw, 150px) 0;
    }

    .section-heading {
      display: grid;
      grid-template-columns: minmax(0, 0.9fr) minmax(280px, 0.55fr);
      align-items: end;
      gap: 48px;
      margin-bottom: clamp(48px, 6vw, 78px);
    }

    .section-kicker {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 0 0 13px;
      color: var(--cinnabar);
      font-family: var(--serif);
      font-size: 0.76rem;
      letter-spacing: 0.22em;
    }

    .section-kicker::before {
      content: "";
      width: 34px;
      height: 1px;
      background: currentColor;
      opacity: 0.72;
    }

    .section-title {
      margin: 0;
      font-family: var(--serif);
      font-size: clamp(2.45rem, 5vw, 4.25rem);
      font-weight: 500;
      line-height: 1.12;
      letter-spacing: 0.1em;
    }

    .section-note {
      margin: 0;
      color: var(--ink-soft);
      font-family: var(--serif);
      font-size: clamp(1rem, 1.4vw, 1.13rem);
      line-height: 2;
    }

    .brush-divider {
      position: absolute;
      left: 50%;
      bottom: -14px;
      width: min(74vw, 960px);
      height: 42px;
      transform: translateX(-50%);
      opacity: 0.26;
      pointer-events: none;
    }

    /* =========================
       首页主视觉：水墨远山
    ========================== */
    .hero {
      position: relative;
      min-height: 600px;
      height: clamp(600px, 68svh, 720px);
      display: grid;
      align-items: center;
      padding: 118px 0 76px;
      isolation: isolate;
      overflow: hidden;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -3;
      background: linear-gradient(90deg, rgba(250, 248, 242, 0.88) 0%, rgba(250, 248, 242, 0.7) 43%, rgba(250, 248, 242, 0.3) 72%, rgba(250, 248, 242, 0.5) 100%);
    }

    .hero::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -2;
      background: linear-gradient(180deg, rgba(247, 244, 235, 0.08), transparent 55%, rgba(242, 238, 227, 0.72));
      pointer-events: none;
    }

    .hero-grid {
      position: relative;
      z-index: 4;
      display: grid;
      grid-template-columns: minmax(0, 1fr) 330px;
      align-items: center;
      gap: clamp(42px, 7vw, 110px);
    }

    .hero-content {
      max-width: 760px;
      padding-top: 18px;
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 15px;
      margin: 0 0 24px;
      color: var(--moss);
      font-family: var(--serif);
      font-size: 0.8rem;
      letter-spacing: 0.28em;
    }

    .hero-eyebrow::before {
      content: "";
      width: 42px;
      height: 1px;
      background: currentColor;
      opacity: 0.58;
    }

    .hero-title {
      margin: 0;
      font-family: var(--serif);
      font-size: clamp(4.2rem, 7.4vw, 6.8rem);
      font-weight: 500;
      line-height: 0.98;
      letter-spacing: 0.11em;
      text-wrap: balance;
    }

    .hero-title .accent-dot {
      color: var(--cinnabar);
      font-size: 0.42em;
      vertical-align: 0.14em;
      margin-left: 0.08em;
    }

    .hero-subtitle {
      margin: 28px 0 0;
      color: var(--ink-soft);
      font-family: var(--serif);
      font-size: clamp(1.12rem, 2vw, 1.48rem);
      letter-spacing: 0.12em;
    }

    .hero-intro {
      max-width: 580px;
      margin-top: 34px;
      padding-left: 22px;
      border-left: 1px solid rgba(164, 68, 52, 0.48);
      color: var(--ink-soft);
      font-size: 1rem;
      line-height: 2.05;
    }

    .hero-actions {
      display: flex;
      align-items: center;
      gap: 30px;
      margin-top: 42px;
    }

    .action-primary,
    .action-secondary {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      font-family: var(--serif);
      letter-spacing: 0.12em;
      transition: color 230ms ease, transform 230ms var(--ease), border-color 230ms ease;
    }

    .action-primary {
      min-width: 126px;
      padding: 8px 20px;
      color: var(--paper-light);
      background: var(--ink);
      border: 1px solid var(--ink);
    }

    .action-primary::after {
      content: "";
      position: absolute;
      inset: 4px;
      border: 1px solid rgba(255,255,255,0.2);
    }

    .action-primary:hover {
      transform: translateY(-2px);
      background: var(--moss-deep);
      border-color: var(--moss-deep);
    }

    .action-secondary {
      padding: 8px 0 6px;
      border-bottom: 1px solid var(--line-strong);
    }

    .action-secondary::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      bottom: -1px;
      height: 1px;
      background: var(--cinnabar);
      transform: scaleX(0);
      transform-origin: right;
      transition: transform 260ms var(--ease);
    }

    .action-secondary:hover::after {
      transform: scaleX(1);
      transform-origin: left;
    }

    .hero-side {
      position: relative;
      align-self: stretch;
      min-height: 350px;
      display: flex;
      align-items: center;
      justify-content: flex-end;
    }

    .hero-vertical-copy {
      position: absolute;
      right: 4px;
      top: 42px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      color: rgba(48, 50, 46, 0.68);
      font-family: var(--serif);
      font-size: 0.9rem;
      letter-spacing: 0.28em;
      writing-mode: vertical-rl;
    }

    .hero-vertical-copy::before {
      content: "";
      width: 1px;
      height: 64px;
      margin: 0 auto 12px;
      background: linear-gradient(var(--moss), transparent);
      opacity: 0.38;
    }

    .hero-note {
      position: relative;
      width: 286px;
      margin-right: 46px;
      padding: 28px 28px 26px;
      color: var(--ink-soft);
      background: rgba(249, 247, 240, 0.72);
      border-top: 1px solid var(--line-strong);
      border-bottom: 1px solid var(--line);
    }

    .hero-note::before {
      content: "";
      position: absolute;
      left: -30px;
      top: 20px;
      width: 52px;
      height: 74px;
      background:
        radial-gradient(ellipse at 40% 55%, rgba(63, 72, 65, 0.22), transparent 58%),
        radial-gradient(ellipse at 70% 35%, rgba(63, 72, 65, 0.12), transparent 48%);
      filter: blur(3px);
      transform: rotate(-14deg);
    }

    .hero-note-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 18px;
      margin-bottom: 20px;
      color: var(--ink);
      font-family: var(--serif);
    }

    .hero-note-head strong {
      font-size: 1.05rem;
      font-weight: 500;
      letter-spacing: 0.18em;
    }

    .hero-note-head time {
      color: var(--ink-faint);
      font-size: 0.72rem;
      letter-spacing: 0.08em;
    }

    .hero-note dl,
    .hero-note dd {
      margin: 0;
    }

    .hero-note dl {
      display: grid;
      gap: 17px;
    }

    .hero-note dl > div {
      display: grid;
      grid-template-columns: 70px 1fr;
      gap: 12px;
      padding-top: 15px;
      border-top: 1px solid var(--line);
    }

    .hero-note dt {
      color: var(--moss);
      font-size: 0.74rem;
      letter-spacing: 0.08em;
    }

    .hero-note dd {
      font-family: var(--serif);
      font-size: 0.94rem;
      line-height: 1.75;
    }

    .hero-landscape {
      position: absolute;
      inset: 0;
      z-index: -4;
      pointer-events: none;
    }

    .hero-landscape img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 56%;
    }

    .scroll-hint {
      position: absolute;
      left: 50%;
      bottom: 28px;
      z-index: 5;
      display: grid;
      justify-items: center;
      gap: 8px;
      color: var(--ink-faint);
      font-family: var(--serif);
      font-size: 0.72rem;
      letter-spacing: 0.25em;
      transform: translateX(-50%);
    }

    .scroll-hint::after {
      content: "";
      width: 1px;
      height: 30px;
      background: linear-gradient(var(--ink-faint), transparent);
    }

    /* =========================
       书斋目录
    ========================== */
    .study-index {
      background:
        linear-gradient(90deg, rgba(73, 81, 74, 0.025), transparent 30%, transparent 70%, rgba(73, 81, 74, 0.025)),
        rgba(250, 248, 242, 0.45);
      border-top: 1px solid rgba(82, 78, 69, 0.08);
      border-bottom: 1px solid rgba(82, 78, 69, 0.08);
    }

    .study-grid {
      display: grid;
      grid-template-columns: 330px minmax(0, 1fr);
      gap: clamp(56px, 8vw, 112px);
      align-items: start;
    }

    .study-intro {
      position: sticky;
      top: 118px;
      padding-top: 12px;
    }

    .study-title {
      margin: 0;
      font-family: var(--serif);
      font-size: clamp(2.35rem, 4.7vw, 4rem);
      font-weight: 500;
      line-height: 1.15;
      letter-spacing: 0.1em;
    }

    .study-intro > p:last-of-type {
      margin: 26px 0 0;
      color: var(--ink-soft);
      font-family: var(--serif);
      line-height: 2;
    }

    .study-mini-painting {
      position: relative;
      width: 100%;
      height: 190px;
      margin-top: 34px;
      overflow: hidden;
      border-top: 1px solid var(--line);
    }

    .study-mini-painting svg {
      width: 100%;
      height: 100%;
    }

    .index-list {
      border-top: 1px solid var(--line-strong);
    }

    .index-item {
      position: relative;
      display: grid;
      grid-template-columns: 60px minmax(150px, 0.48fr) minmax(220px, 1fr) 70px;
      align-items: center;
      gap: 24px;
      min-height: 118px;
      border-bottom: 1px solid var(--line);
      transition: color 240ms ease, transform 260ms var(--ease), background-color 240ms ease;
    }

    .index-item::before {
      content: "";
      position: absolute;
      left: 0;
      top: 50%;
      width: 0;
      height: 1px;
      background: var(--cinnabar);
      transition: width 320ms var(--ease);
    }

    .index-item:hover {
      color: var(--moss-deep);
      background: linear-gradient(90deg, rgba(164, 68, 52, 0.035), transparent 42%);
      transform: translateX(6px);
    }

    .index-item:hover::before {
      width: 28px;
    }

    .index-number {
      color: var(--cinnabar);
      font-family: var(--serif);
      font-size: 0.88rem;
      letter-spacing: 0.12em;
      transition: transform 260ms var(--ease);
    }

    .index-item:hover .index-number {
      transform: translateX(32px);
    }

    .index-name {
      font-family: var(--serif);
      font-size: clamp(1.28rem, 2vw, 1.7rem);
      letter-spacing: 0.08em;
    }

    .index-desc,
    .index-count {
      color: var(--ink-soft);
      font-size: 0.88rem;
    }

    .index-count {
      text-align: right;
      font-family: var(--serif);
    }

    /* =========================
       最新文章：水墨横卷
    ========================== */
    .latest {
      background:
        radial-gradient(ellipse at 100% 22%, rgba(73, 82, 74, 0.08), transparent 27%),
        radial-gradient(ellipse at 0% 76%, rgba(73, 82, 74, 0.055), transparent 28%);
    }

    .scroll-list {
      position: relative;
      scroll-margin-top: 76px;
      display: grid;
      gap: clamp(40px, 5vw, 64px);
    }

    .scroll-list::before {
      content: "";
      position: absolute;
      left: 5%;
      right: 5%;
      top: -22px;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--line-strong), transparent);
    }

    .article-scroll {
      position: relative;
      display: grid;
      grid-template-columns: 30px minmax(0, 1fr) 30px;
      min-height: 280px;
      filter: drop-shadow(0 16px 24px rgba(63, 54, 41, 0.08));
      transition: transform 300ms var(--ease), filter 300ms ease;
    }

    .article-scroll:nth-child(2) {
      margin-left: clamp(0px, 4vw, 52px);
      margin-right: clamp(0px, 1vw, 12px);
    }

    .article-scroll:nth-child(3) {
      margin-left: clamp(0px, 1vw, 14px);
      margin-right: clamp(0px, 4vw, 54px);
    }

    .article-scroll:hover {
      transform: translateY(-5px);
      filter: drop-shadow(0 20px 30px rgba(63, 54, 41, 0.12));
    }

    .scroll-axis {
      position: relative;
      z-index: 5;
      margin: -10px 0;
      background:
        linear-gradient(90deg, rgba(68, 51, 34, 0.78), rgba(153, 111, 67, 0.76) 34%, rgba(84, 58, 36, 0.82) 74%, rgba(48, 37, 27, 0.9)),
        #725037;
      border: 1px solid rgba(54, 40, 28, 0.44);
      box-shadow:
        inset 4px 0 8px rgba(255,255,255,0.12),
        inset -4px 0 8px rgba(21, 15, 10, 0.18),
        0 8px 16px rgba(45, 33, 23, 0.12);
    }

    .scroll-axis::before,
    .scroll-axis::after {
      content: "";
      position: absolute;
      left: 50%;
      width: 46px;
      height: 14px;
      border-radius: 50%;
      background: linear-gradient(180deg, #967052, #523a28 72%);
      border: 1px solid rgba(48, 35, 24, 0.45);
      transform: translateX(-50%);
      box-shadow: inset 0 2px 3px rgba(255,255,255,0.12);
    }

    .scroll-axis::before { top: -7px; }
    .scroll-axis::after { bottom: -7px; }

    .scroll-paper {
      position: relative;
      min-width: 0;
      display: grid;
      grid-template-columns: 180px minmax(0, 1fr) 150px;
      align-items: center;
      gap: clamp(26px, 4vw, 58px);
      padding: clamp(38px, 5vw, 66px) clamp(34px, 5vw, 72px);
      overflow: hidden;
      background:
        linear-gradient(90deg, rgba(103, 89, 68, 0.10), transparent 4%, transparent 96%, rgba(103, 89, 68, 0.10)),
        radial-gradient(circle at 52% 48%, rgba(255,255,255,0.58), transparent 44%),
        #efe7d8;
      border-top: 1px solid rgba(118, 97, 68, 0.3);
      border-bottom: 1px solid rgba(118, 97, 68, 0.28);
      box-shadow:
        inset 0 16px 24px rgba(255,255,255,0.18),
        inset 0 -14px 22px rgba(100, 81, 56, 0.07);
    }

    .scroll-paper::before {
      content: "";
      position: absolute;
      inset: 15px 18px;
      z-index: 1;
      pointer-events: none;
      border: 1px solid rgba(112, 96, 73, 0.15);
      clip-path: polygon(0 0, 98.5% 0, 100% 6%, 99.2% 100%, 1% 99.4%, 0 92%);
    }

    .scroll-paper::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: 0.22;
      background-image:
        repeating-linear-gradient(90deg, transparent 0 46px, rgba(97, 80, 58, 0.06) 47px, transparent 48px),
        url("data:image/svg+xml,%3Csvg viewBox='0 0 150 150' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='f'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.62' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23f)' opacity='.34'/%3E%3C/svg%3E");
      mix-blend-mode: multiply;
    }

    .scroll-paper > *:not(.scroll-ink) {
      position: relative;
      z-index: 3;
    }

    .scroll-ink {
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      opacity: 0.72;
    }

    .scroll-ink svg {
      width: 100%;
      height: 100%;
    }

    .scroll-seal {
      position: absolute !important;
      right: 28px;
      top: 22px;
      width: 42px;
      aspect-ratio: 1;
      display: grid;
      place-items: center;
      color: rgba(249, 237, 226, 0.94);
      background: rgba(164, 68, 52, 0.88);
      border: 1px solid rgba(127, 48, 38, 0.7);
      font-family: var(--serif);
      font-size: 0.72rem;
      line-height: 1.2;
      text-align: center;
      transform: rotate(-3deg);
      box-shadow: inset 0 0 0 3px rgba(255,255,255,0.12);
    }

    .post-meta {
      align-self: stretch;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 7px;
      padding-right: 24px;
      border-right: 1px solid rgba(74, 76, 69, 0.2);
      color: var(--ink-soft);
      font-size: 0.82rem;
    }

    .post-meta::before {
      content: attr(data-index);
      display: block;
      margin-bottom: 6px;
      color: var(--cinnabar);
      font-family: var(--serif);
      font-size: 1.15rem;
      letter-spacing: 0.16em;
    }

    .post-meta time {
      font-family: var(--serif);
      letter-spacing: 0.04em;
    }

    .post-meta .category {
      margin-top: 8px;
      color: var(--moss-deep);
      font-family: var(--serif);
      font-size: 0.98rem;
      letter-spacing: 0.08em;
    }

    .reading-time {
      color: var(--ink-faint);
    }

    .post-main {
      min-width: 0;
      padding-right: 18px;
    }

    .post-title {
      margin: 0;
      font-family: var(--serif);
      font-size: clamp(1.7rem, 3.1vw, 2.65rem);
      font-weight: 500;
      line-height: 1.4;
      letter-spacing: 0.045em;
      text-wrap: balance;
    }

    .post-title a {
      background-image: linear-gradient(var(--cinnabar), var(--cinnabar));
      background-repeat: no-repeat;
      background-position: left 100%;
      background-size: 0 1px;
      transition: color 250ms ease, background-size 340ms var(--ease);
    }

    .article-scroll:hover .post-title a {
      color: #1f2420;
      background-size: 100% 1px;
    }

    .post-excerpt {
      max-width: 650px;
      margin: 22px 0 0;
      color: var(--ink-soft);
      font-family: var(--serif);
      font-size: 1rem;
      line-height: 1.95;
    }

    .post-tags {
      align-self: center;
      display: grid;
      gap: 10px;
      justify-items: end;
      color: var(--ink-soft);
      font-family: var(--serif);
      font-size: 0.88rem;
      letter-spacing: 0.08em;
    }

    .post-tags::before {
      content: "题签";
      margin-bottom: 4px;
      color: var(--cinnabar);
      font-size: 0.72rem;
      letter-spacing: 0.18em;
    }

    .post-tags span::before {
      content: "「";
      color: rgba(164, 68, 52, 0.62);
    }

    .post-tags span::after {
      content: "」";
      color: rgba(164, 68, 52, 0.62);
    }

    .all-posts {
      display: flex;
      justify-content: flex-end;
      margin-top: 42px;
    }

    .all-posts a {
      position: relative;
      padding: 8px 30px 8px 0;
      color: var(--ink-soft);
      font-family: var(--serif);
      letter-spacing: 0.12em;
    }

    .all-posts a::before {
      content: "";
      position: absolute;
      right: 0;
      top: 50%;
      width: 20px;
      height: 1px;
      background: var(--cinnabar);
      transition: width 260ms var(--ease);
    }

    .all-posts a:hover::before {
      width: 28px;
    }

    /* =========================
       案头近况：墨色过渡区
    ========================== */
    .desk {
      position: relative;
      color: rgba(248, 246, 239, 0.92);
      background:
        radial-gradient(ellipse at 18% 38%, rgba(255,255,255,0.045), transparent 33%),
        radial-gradient(ellipse at 80% 12%, rgba(164,68,52,0.08), transparent 22%),
        linear-gradient(135deg, #3d4540, #303531 60%, #3a403b);
      overflow: hidden;
    }

    .desk::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      opacity: 0.22;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 220 220' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='d'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.46' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23d)' opacity='.6'/%3E%3C/svg%3E");
      mix-blend-mode: soft-light;
    }

    .desk::after {
      content: "";
      position: absolute;
      right: -7%;
      bottom: -22%;
      width: min(50vw, 760px);
      aspect-ratio: 1.4;
      border-radius: 50%;
      border: 1px solid rgba(235, 232, 222, 0.08);
      box-shadow:
        0 0 0 34px rgba(235,232,222,0.025),
        0 0 0 82px rgba(235,232,222,0.015);
      transform: rotate(-8deg);
    }

    .desk .section-kicker {
      color: #ce8b7e;
    }

    .desk .section-title {
      color: #f1eee6;
    }

    .desk .section-note {
      color: rgba(242, 239, 230, 0.64);
    }

    .desk-grid {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.8fr);
      gap: clamp(32px, 5vw, 70px);
    }

    .now-panel,
    .fragment-panel {
      position: relative;
      min-width: 0;
      border-top: 1px solid rgba(240, 236, 226, 0.28);
      border-bottom: 1px solid rgba(240, 236, 226, 0.12);
      background: rgba(255,255,255,0.025);
    }

    .now-panel {
      padding: 30px 34px 18px;
    }

    .panel-mark {
      position: absolute;
      right: 26px;
      top: -20px;
      width: 42px;
      aspect-ratio: 1;
      display: grid;
      place-items: center;
      color: rgba(248, 238, 229, 0.94);
      background: var(--cinnabar);
      border: 1px solid rgba(118, 42, 33, 0.8);
      font-family: var(--serif);
      transform: rotate(4deg);
    }

    .now-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 20px;
      padding-bottom: 20px;
      color: rgba(247,244,235,0.9);
      font-family: var(--serif);
    }

    .now-head span {
      font-size: 1.1rem;
      letter-spacing: 0.15em;
    }

    .now-head time {
      color: rgba(247,244,235,0.45);
      font-size: 0.78rem;
    }

    .now-list {
      border-top: 1px solid rgba(240, 236, 226, 0.12);
    }

    .now-row {
      display: grid;
      grid-template-columns: 78px minmax(0, 1fr) 64px;
      gap: 20px;
      align-items: center;
      min-height: 92px;
      border-bottom: 1px solid rgba(240, 236, 226, 0.11);
    }

    .now-label {
      color: #d79a8d;
      font-size: 0.78rem;
      letter-spacing: 0.08em;
    }

    .now-row strong {
      color: rgba(248,246,239,0.88);
      font-family: var(--serif);
      font-size: 1.02rem;
      font-weight: 400;
      line-height: 1.7;
    }

    .now-state {
      justify-self: end;
      color: rgba(248,246,239,0.43);
      font-size: 0.74rem;
    }

    .fragment-panel {
      display: grid;
      grid-template-rows: 210px 1fr;
      overflow: hidden;
    }

    .fragment-art {
      position: relative;
      overflow: hidden;
      border-bottom: 1px solid rgba(240,236,226,0.12);
    }

    .fragment-art svg {
      width: 100%;
      height: 100%;
    }

    .fragment-copy {
      padding: 26px 30px 30px;
    }

    .fragment-label {
      margin: 0 0 12px;
      color: #d79a8d;
      font-family: var(--serif);
      font-size: 0.78rem;
      letter-spacing: 0.18em;
    }

    .fragment-copy blockquote {
      margin: 0;
      color: rgba(248,246,239,0.88);
      font-family: var(--serif);
      font-size: clamp(1.1rem, 1.8vw, 1.35rem);
      line-height: 1.9;
    }

    .fragment-source {
      margin: 18px 0 0;
      color: rgba(248,246,239,0.4);
      font-size: 0.78rem;
      text-align: right;
    }

    /* =========================
       关于此间
    ========================== */
    .about {
      overflow: hidden;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.28), transparent 48%),
        var(--paper);
    }

    .about-grid {
      display: grid;
      grid-template-columns: minmax(0, 0.85fr) minmax(380px, 0.72fr);
      gap: clamp(54px, 9vw, 130px);
      align-items: center;
    }

    .about-text {
      max-width: 650px;
      margin-top: 34px;
      color: var(--ink-soft);
      font-family: var(--serif);
      font-size: clamp(1rem, 1.4vw, 1.15rem);
      line-height: 2.15;
    }

    .about-text p {
      margin: 0 0 14px;
    }

    .about-signature {
      display: inline-block;
      margin-top: 28px;
      padding: 7px 0;
      border-bottom: 1px solid rgba(164,68,52,0.45);
      color: var(--moss-deep);
      font-family: var(--serif);
      letter-spacing: 0.16em;
    }

    .about-topics {
      display: flex;
      flex-wrap: wrap;
      gap: 18px 28px;
      margin-top: 34px;
      color: var(--ink-faint);
      font-family: var(--serif);
      font-size: 0.88rem;
    }

    .about-topics span::before {
      content: "·";
      margin-right: 8px;
      color: var(--cinnabar);
    }

    .ink-orbit {
      position: relative;
      min-height: 510px;
      display: grid;
      place-items: center;
    }

    .ink-circle {
      position: absolute;
      width: min(38vw, 430px);
      aspect-ratio: 1;
      border-radius: 50%;
      border: 12px solid transparent;
      background:
        radial-gradient(circle at 51% 49%, var(--paper) 0 57%, transparent 58%),
        conic-gradient(from 12deg,
          rgba(44,48,44,0.82),
          rgba(63,70,64,0.4) 12%,
          rgba(44,48,44,0.78) 22%,
          rgba(63,70,64,0.22) 36%,
          rgba(44,48,44,0.72) 52%,
          rgba(63,70,64,0.28) 66%,
          rgba(44,48,44,0.84) 82%,
          rgba(63,70,64,0.3));
      filter: blur(0.35px);
      opacity: 0.72;
      transform: rotate(-12deg) scaleX(1.02);
      -webkit-mask: radial-gradient(circle, transparent 0 56%, #000 57% 66%, transparent 67%);
      mask: radial-gradient(circle, transparent 0 56%, #000 57% 66%, transparent 67%);
    }

    .ink-circle::before,
    .ink-circle::after {
      content: "";
      position: absolute;
      border-radius: 50%;
      background: rgba(46, 51, 47, 0.16);
      filter: blur(4px);
    }

    .ink-circle::before {
      width: 42px;
      height: 20px;
      left: -6px;
      top: 52%;
      transform: rotate(-20deg);
    }

    .ink-circle::after {
      width: 30px;
      height: 14px;
      right: 8px;
      bottom: 20%;
      transform: rotate(18deg);
    }

    .bamboo {
      position: relative;
      z-index: 2;
      width: min(31vw, 350px);
      overflow: visible;
    }

    .about-seal {
      position: absolute;
      z-index: 4;
      right: 11%;
      bottom: 13%;
      width: 58px;
      aspect-ratio: 1;
      display: grid;
      place-items: center;
      color: #f8eee4;
      background: rgba(164,68,52,0.9);
      border: 1px solid var(--cinnabar-deep);
      font-family: var(--serif);
      font-size: 0.72rem;
      line-height: 1.45;
      text-align: center;
      transform: rotate(4deg);
      box-shadow: inset 0 0 0 4px rgba(255,255,255,0.13);
    }

    /* =========================
       动画
    ========================== */
    .hero-content {
      animation: hero-in 300ms var(--ease) both;
    }

    .hero-note {
      animation: note-in 300ms 40ms var(--ease) both;
    }

    .reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 300ms ease, transform 300ms var(--ease);
    }

    .reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    @keyframes hero-in {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes note-in {
      from { opacity: 0; transform: translateX(20px); }
      to { opacity: 1; transform: translateX(0); }
    }

