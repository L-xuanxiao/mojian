      }

      .hero-landscape {
        height: 100%;
      }

      .study-grid {
        grid-template-columns: 1fr;
      }

      .study-intro {
        position: static;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 260px;
        gap: 36px;
      }

      .study-mini-painting {
        height: 180px;
        margin-top: 0;
      }

      .index-item {
        grid-template-columns: 42px minmax(150px, 0.7fr) minmax(180px, 1fr) 58px;
      }


      .about-grid {
        grid-template-columns: 1fr;
      }

      .ink-orbit {
        min-height: 420px;
      }

      .ink-circle {
        width: min(62vw, 390px);
      }

      .bamboo {
        width: min(48vw, 320px);
      }
    }

    @media (max-width: 620px) {
      .hero {
        min-height: 570px;
        padding: 104px 0 62px;
      }

      .hero-title {
        font-size: clamp(3.4rem, 18vw, 5.4rem);
        letter-spacing: 0.07em;
      }

      .hero-subtitle {
        margin-top: 22px;
        font-size: 1rem;
        letter-spacing: 0.08em;
      }

      .hero-intro {
        margin-top: 26px;
        font-size: 0.92rem;
      }

      .hero-actions {
        gap: 22px;
        margin-top: 32px;
      }

      .action-primary {
        min-width: 112px;
        padding-inline: 16px;
      }

      .hero-note {
        padding: 22px 20px;
