      }

      .fragment-art {
        min-height: 300px;
        border-right: 1px solid rgba(240,236,226,0.12);
        border-bottom: 0;
      }
    }

    @media (max-width: 820px) {
      .section-heading {
        grid-template-columns: 1fr;
