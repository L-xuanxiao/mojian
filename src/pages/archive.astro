---
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatDate, getPublishedPosts } from '../lib/posts';

const BASE = import.meta.env.BASE_URL;
const posts = await getPublishedPosts();
const years = new Map<number, typeof posts>();

for (const post of posts) {
  const year = post.data.pubDate.getFullYear();
  const list = years.get(year) ?? [];
  list.push(post);
  years.set(year, list);
}
---

<BaseLayout title="归档" description="墨笺的年月归档。">
  <section class="archive page-shell">
    <header>
      <p class="page-kicker">循时而记</p>
      <h1 class="page-display-title">卷藏</h1>
    </header>

    <div class="year-list">
      {[...years.entries()].map(([year, yearPosts]) => (
        <section class="year" aria-labelledby={`year-${year}`}>
          <h2 id={`year-${year}`}>{year}</h2>
          <ol>
            {yearPosts.map((post) => (
              <li>
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
                <a href={`${BASE}posts/${post.id}/`}>{post.data.title}</a>
                <span>{post.data.category}</span>
              </li>
            ))}
          </ol>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .archive {
    position: relative;
    padding-top: clamp(4rem, 9vw, 8rem);
  }

  .archive::before {
    position: absolute;
    top: 3rem;
    left: 50%;
    width: min(72vw, 44rem);
    aspect-ratio: 1;
    border: 1px solid rgb(83 79 70 / 9%);
    border-radius: 50%;
    content: '';
    pointer-events: none;
    transform: translateX(-50%);
  }

  header {
    position: relative;
    text-align: center;
  }

  .page-display-title {
    letter-spacing: 0.2em;
  }

  .year-list {
    position: relative;
    width: min(100%, 52rem);
    margin: clamp(4rem, 9vw, 7rem) auto 0;
    padding: clamp(1rem, 3vw, 2rem) clamp(1.2rem, 4vw, 3rem);
    border-block: 1px solid var(--line-strong);
    background:
      repeating-linear-gradient(180deg, transparent 0 55px, rgb(83 79 70 / 6%) 55px 56px),
      rgb(251 249 243 / 34%);
  }

  .year {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 2rem;
    padding-block: 2rem;
    border-top: 1px solid var(--line-strong);
  }

  .year:first-child {
    border-top: 0;
  }

  h2 {
    margin: 0;
    color: var(--moss-deep);
    font-family: var(--serif);
    font-size: 1.8rem;
    font-weight: 500;
  }

  ol {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li {
    display: grid;
    grid-template-columns: 9rem 1fr auto;
    align-items: baseline;
    gap: 1.2rem;
    padding-block: 0.8rem;
  }

  time,
  li span {
    color: var(--ink-faint);
    font-size: 0.85rem;
  }

  a {
    font-family: var(--serif);
    font-size: 1.15rem;
    letter-spacing: 0.08em;
    text-decoration: none;
  }

  a:hover {
    color: var(--moss-deep);
  }

  @media (max-width: 640px) {
    .year {
      grid-template-columns: 1fr;
      gap: 0.8rem;
    }

    li {
      grid-template-columns: 1fr auto;
      gap: 0.4rem 1rem;
    }

    time {
      grid-column: 1 / -1;
    }
  }
</style>
