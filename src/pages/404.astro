---
import BaseLayout from '../layouts/BaseLayout.astro';

const BASE = import.meta.env.BASE_URL;
---

<BaseLayout title="未寻得此页" description="你访问的页面不存在。">
  <section class="not-found page-shell">
    <p class="code page-kicker">四〇四</p>
    <h1 class="page-display-title">山径已隐，未寻得此页。</h1>
    <p>也许它从未写下，或已随旧页远去。</p>
    <a href={BASE}>返回墨笺</a>
  </section>
</BaseLayout>

<style>
  .not-found {
    position: relative;
    display: grid;
    min-height: 60vh;
    place-content: center;
    justify-items: center;
    padding-block: 5rem;
    text-align: center;
  }

  .not-found::before {
    position: absolute;
    z-index: -1;
    top: 50%;
    left: 50%;
    width: min(70vw, 33rem);
    aspect-ratio: 1;
    border: 1px solid rgb(83 79 70 / 12%);
    border-radius: 50%;
    content: '';
    transform: translate(-50%, -50%);
  }

  .code {
    letter-spacing: 0.5em;
  }

  .page-display-title {
    margin: 1.2rem 0;
    letter-spacing: 0.1em;
  }

  .not-found > p:not(.code) {
    color: var(--ink-soft);
    line-height: 1.8;
  }

  a {
    margin-top: 2rem;
    color: var(--moss-deep);
    font-family: var(--serif);
    letter-spacing: 0.14em;
  }
</style>
