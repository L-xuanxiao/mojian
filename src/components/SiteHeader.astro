---
const BASE = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;
const navItems = [
  { href: BASE, label: '首页' },
  { href: `${BASE}archive/`, label: '归档' },
  { href: `${BASE}about/`, label: '关于' },
];

const isActive = (href: string) =>
  href === BASE ? pathname === BASE : pathname.startsWith(href);
---

<header class="site-header">
  <div class="page-shell header-inner">
    <a class="brand" href={BASE} aria-label="墨笺首页">
      <span class="brand-name">墨笺</span>
      <span class="seal" aria-hidden="true"><i>墨</i><i>笺</i></span>
    </a>

    <nav aria-label="主导航">
      <ul>
        {navItems.map((item) => (
          <li>
            <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    z-index: 30;
    top: 0;
    padding-top: 0.875rem;
  }

  .header-inner {
    position: relative;
    isolation: isolate;
    display: flex;
    min-height: 5.5rem;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-inline: 1.5rem;
    border: 1px solid rgb(255 255 255 / 58%);
    border-radius: 999px;
    background-color: rgb(238 229 210 / 72%);
    background-image: linear-gradient(180deg, rgb(255 255 255 / 22%), rgb(210 201 183 / 12%));
    -webkit-backdrop-filter: blur(14px) saturate(145%);
    backdrop-filter: blur(14px) saturate(145%);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 74%),
      inset 0 -1px 0 rgb(67 83 73 / 14%),
      0 12px 34px rgb(48 40 31 / 12%);
  }

  .header-inner::before {
    position: absolute;
    z-index: 0;
    inset: 1px;
    border-radius: inherit;
    content: '';
    pointer-events: none;
    background:
      radial-gradient(circle at 12% -140%, rgb(255 255 255 / 90%), transparent 46%),
      linear-gradient(105deg, rgb(255 255 255 / 22%), transparent 28%, transparent 72%, rgb(255 255 255 / 14%));
    box-shadow: inset 0 0 0 1px rgb(255 255 255 / 16%);
  }

  .header-inner > * {
    position: relative;
    z-index: 1;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    text-decoration: none;
  }

  .brand-name {
    font-size: 1.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
  }

  .seal {
    display: grid;
    width: 1.8rem;
    height: 1.8rem;
    grid-template-columns: 1fr 1fr;
    place-items: center;
    border: 1px solid var(--color-cinnabar);
    color: var(--color-cinnabar);
    font-size: 0.56rem;
    line-height: 1;
    transform: rotate(-2deg);
  }

  .seal i {
    font-style: normal;
  }

  ul {
    display: flex;
    align-items: center;
    gap: clamp(1.1rem, 4vw, 3rem);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  nav a {
    position: relative;
    display: inline-flex;
    min-height: 2.625rem;
    align-items: center;
    padding: 0.65rem 0.9rem;
    border-radius: 999px;
    color: var(--color-ink-soft);
    text-decoration: none;
    letter-spacing: 0.18em;
    transition: color 200ms ease, background-color 200ms ease, box-shadow 200ms ease;
  }

  nav a:hover,
  nav a[aria-current='page'] {
    color: var(--color-ink);
    background: rgb(255 255 255 / 38%);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 70%),
      inset 0 0 0 1px rgb(67 83 73 / 8%);
  }

  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .header-inner {
      background-color: rgb(238 229 210 / 97%);
    }
  }

  @media (prefers-reduced-transparency: reduce) {
    .header-inner {
      background-color: rgb(238 229 210 / 98%);
      -webkit-backdrop-filter: none;
      backdrop-filter: none;
    }

    .header-inner::before {
      opacity: 0.32;
    }
  }

  @media (prefers-contrast: more) {
    .header-inner {
      border-color: rgb(33 29 24 / 50%);
      background-color: rgb(238 229 210 / 96%);
    }

    nav a[aria-current='page'] {
      box-shadow: inset 0 0 0 1px currentColor;
    }
  }

  @media (max-width: 560px) {
    .site-header {
      padding-top: 0.625rem;
    }

    .header-inner {
      min-height: 4.5rem;
      padding-inline: 0.875rem;
    }

    .brand-name {
      font-size: 1.35rem;
    }

    .seal {
      display: none;
    }

    ul {
      gap: 0.9rem;
    }

    nav a {
      font-size: 0.9rem;
      letter-spacing: 0.08em;
    }
  }
</style>
