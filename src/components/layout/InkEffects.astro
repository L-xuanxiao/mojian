  { kind: 'petal', shape: 'split', tone: 'plum', depth: 'far', path: 'd', x: 48, size: 8, duration: 30.1, delay: -23.8, opacity: 0.28, density: 'core', inner: false, drifts: [20, -12, 30, 9] },
  { kind: 'petal', shape: 'pointed', tone: 'apricot', depth: 'far', path: 'b', x: 70, size: 10, duration: 34.5, delay: -14.6, opacity: 0.35, density: 'core', inner: false, drifts: [-24, 15, -36, -11] },
  { kind: 'petal', shape: 'folded', tone: 'cinnabar', depth: 'far', path: 'e', x: 87, size: 11, duration: 28.7, delay: -3.4, opacity: 0.39, density: 'compact', inner: false, drifts: [28, -17, 40, 13] },
  { kind: 'petal', shape: 'cup', tone: 'ivory', depth: 'far', path: 'c', x: 98, size: 7, duration: 33.8, delay: -26.1, opacity: 0.26, density: 'wide', inner: false, drifts: [-18, 11, -28, -8] },
