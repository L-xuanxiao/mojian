---
// 首页「近来所记」手卷卡片。样式与 index.astro 抽取前保持一致（scoped 平移）。
import type { CollectionEntry } from 'astro:content';
import { siteConfig } from '../../config/siteConfig';
import { formatDate } from '../../lib/posts';

interface Props {
  post: CollectionEntry<'blog'>;
  /** 卡片序号（从 0 起），决定印章字与水墨变体 */
  index: number;
}

const { post, index } = Astro.props;
const BASE = import.meta.env.BASE_URL;

const SEALS = ['壹', '贰', '叁', '肆', '伍', '陆', '柒', '捌', '玖'] as const;
const seal = SEALS[index % SEALS.length];
const indexLabel = String(index + 1).padStart(2, '0');

// 中文阅读速度约 400 字/分钟
const charCount = (post.body ?? '').replace(/\s/g, '').length;
const minutes = Math.max(1, Math.round(charCount / 400));

const tags = post.data.tags.slice(0, siteConfig.postList.tagsMax);
const variant = index % 3;
const filterId = `postSoft${index}`;
---

<article class="article-scroll reveal">
  <div class="scroll-axis" aria-hidden="true"></div>
  <div class="scroll-paper">
    <div class="scroll-ink" aria-hidden="true">
      {variant === 0 && (
        <svg viewBox="0 0 1100 300" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <defs><filter id={filterId}><feGaussianBlur stdDeviation="4" /></filter></defs>
          <circle cx="950" cy="82" r="32" fill="#a44434" fill-opacity=".08" />
          <path d="M690 228C760 184 804 197 854 157C900 120 936 147 977 177C1015 205 1054 183 1100 150V300H680Z" fill="#586258" fill-opacity=".09" filter={`url(#${filterId})`} />
          <path d="M760 260C827 225 878 241 925 214C976 185 1022 221 1100 194V300H740Z" fill="#2f3530" fill-opacity=".07" />
          <path d="M80 70c72-18 121-10 180 10" fill="none" stroke="#454c46" stroke-opacity=".07" stroke-width="12" filter={`url(#${filterId})`} />
        </svg>
      )}
      {variant === 1 && (
        <svg viewBox="0 0 1100 300" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <defs><filter id={filterId}><feGaussianBlur stdDeviation="4" /></filter></defs>
          <path d="M0 230C76 196 126 205 190 161C251 120 292 154 338 184C379 211 422 190 478 151V300H0Z" fill="#586258" fill-opacity=".075" filter={`url(#${filterId})`} />
          <path d="M0 264C86 230 153 249 218 216C279 186 335 224 414 198V300H0Z" fill="#303631" fill-opacity=".06" />
          <path d="M928 88c35-18 71-18 110-2" fill="none" stroke="#495149" stroke-opacity=".08" stroke-width="14" filter={`url(#${filterId})`} />
          <circle cx="134" cy="78" r="26" fill="#a44434" fill-opacity=".065" />
        </svg>
      )}
      {variant === 2 && (
        <svg viewBox="0 0 1100 300" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <defs><filter id={filterId}><feGaussianBlur stdDeviation="4" /></filter></defs>
          <path d="M650 244C723 211 777 224 834 190C895 154 937 192 986 209C1028 224 1064 213 1100 194V300H630Z" fill="#586258" fill-opacity=".08" filter={`url(#${filterId})`} />
          <path d="M720 270C800 241 849 252 908 229C970 205 1017 238 1100 218V300H700Z" fill="#303631" fill-opacity=".055" />
          <path d="M128 84c64-22 121-17 185 3" fill="none" stroke="#4b534c" stroke-opacity=".08" stroke-width="15" filter={`url(#${filterId})`} />
          <path d="M228 132c16-9 28-8 42 2m24-17c13-7 24-6 35 2" fill="none" stroke="#343a35" stroke-opacity=".14" stroke-linecap="round" />
        </svg>
      )}
    </div>
    <span class="scroll-seal" aria-hidden="true">卷<br />{seal}</span>
    <div class="post-meta" data-index={indexLabel}>
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
      <span class="category">{post.data.category}</span>
      <span class="reading-time">约 {minutes} 分钟</span>
    </div>
    <div class="post-main">
      <h3 class="post-title"><a href={`${BASE}posts/${post.id}/`} aria-label={`阅读：${post.data.title}`}>{post.data.title}</a></h3>
      <p class="post-excerpt">{post.data.description}</p>
    </div>
    <div class="post-tags" aria-label="文章标签">
      {tags.map((tag) => <span>{tag}</span>)}
    </div>
  </div>
  <div class="scroll-axis" aria-hidden="true"></div>
</article>

<style>
  .article-scroll {
    --scroll-motion: 520ms cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: 12px minmax(0, 1fr) 12px;
    height: 180px;
    min-height: 0;
    filter: drop-shadow(0 10px 18px rgba(63, 54, 41, 0.09));
    transition: filter var(--scroll-motion);
  }

  .article-scroll:nth-child(2) {
    margin-left: clamp(0px, 4vw, 52px);
    margin-right: clamp(0px, 1vw, 12px);
  }

  .article-scroll:nth-child(3) {
    margin-left: clamp(0px, 1vw, 14px);
    margin-right: clamp(0px, 4vw, 54px);
  }

  .article-scroll:hover,
  .article-scroll:focus-within {
    filter: drop-shadow(0 14px 24px rgba(63, 54, 41, 0.12));
  }

  .scroll-axis {
    position: relative;
    z-index: 2;
    margin: -3px 0;
    border-radius: 6px;
    background:
      repeating-linear-gradient(180deg, transparent 0 17px, rgba(58, 42, 30, 0.05) 18px, transparent 19px),
      linear-gradient(90deg, #57453a, #79614e 30%, #8a7060 50%, #6d584a 72%, #524239);
    border: 1px solid rgba(72, 58, 46, 0.22);
    transform: translateX(7px);
    box-shadow:
      inset 2px 0 4px rgba(255,255,255,0.1),
      inset -2px 0 4px rgba(30, 24, 19, 0.1),
      0 4px 8px rgba(45, 38, 31, 0.08);
    transition: transform var(--scroll-motion);
    will-change: transform;
  }

  .scroll-axis:last-child {
    transform: translateX(-7px);
  }

  .article-scroll:hover .scroll-axis,
  .article-scroll:focus-within .scroll-axis {
    transform: translateX(0);
  }

  .scroll-axis::before,
  .scroll-axis::after {
    content: "";
    position: absolute;
    left: 50%;
    width: 16px;
    height: 6px;
    border-radius: 50%;
    background:
      radial-gradient(ellipse at 48% 30%, rgba(255,255,255,0.12), transparent 40%),
      linear-gradient(180deg, #7d6852, #5a4a3c 78%);
    border: 1px solid rgba(72, 58, 46, 0.26);
    transform: translateX(-50%);
    box-shadow: inset 0 1px 2px rgba(255,255,255,0.1);
  }

  .scroll-axis::before { top: -3px; }
  .scroll-axis::after { bottom: -3px; }

  .scroll-paper {
    position: relative;
    z-index: 3;
    min-width: 0;
    height: 100%;
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr);
    align-items: center;
    gap: 6px 18px;
    padding: 20px 26px 16px;
    overflow: hidden;
    clip-path: polygon(6px 1%, 18% 0, 41% 1.1%, 64% 0.2%, 84% 1.2%, calc(100% - 6px) 0.5%, calc(100% - 5px) 99%, 78% 98.7%, 55% 100%, 31% 98.8%, 7px 100%);
    transform: scaleX(0.985);
    transform-origin: center;
    background-color: #f1ead9;
    background-image:
      url("data:image/svg+xml,%3Csvg viewBox='0 0 220 220' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='f'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.52' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23f)' opacity='.15'/%3E%3C/svg%3E"),
      radial-gradient(ellipse at 20% 22%, rgba(123, 96, 63, 0.05), transparent 32%),
      radial-gradient(ellipse at 50% 42%, rgba(255, 252, 244, 0.62), transparent 62%),
      linear-gradient(180deg, transparent 0 6px, rgba(122, 94, 58, 0.13) 6px 7px, transparent 7px calc(100% - 7px), rgba(122, 94, 58, 0.11) calc(100% - 7px) calc(100% - 6px), transparent calc(100% - 6px)),
      linear-gradient(180deg, rgba(255,255,255,0.22), transparent 22%, transparent 78%, rgba(88, 65, 39, 0.07)),
      linear-gradient(90deg, rgba(112, 80, 44, 0.15), transparent 8%, transparent 92%, rgba(112, 80, 44, 0.14));
    background-size: 220px 220px, auto, auto, auto, auto, auto;
    background-blend-mode: soft-light, normal, normal, normal, normal, normal;
    border-top: 1px solid rgba(118, 97, 68, 0.16);
    border-bottom: 1px solid rgba(118, 97, 68, 0.14);
    box-shadow:
      inset 22px 0 22px -8px rgba(99, 71, 40, 0.1),
      inset -22px 0 22px -8px rgba(99, 71, 40, 0.09),
      inset 0 8px 12px rgba(255,255,255,0.16),
      inset 0 -8px 13px rgba(95, 71, 45, 0.07);
    transition: transform var(--scroll-motion), clip-path var(--scroll-motion), box-shadow var(--scroll-motion);
    will-change: transform, clip-path;
  }

  .article-scroll:hover .scroll-paper,
  .article-scroll:focus-within .scroll-paper {
    clip-path: polygon(2px 1%, 18% 0, 41% 1.1%, 64% 0.2%, 84% 1.2%, calc(100% - 2px) 0.5%, calc(100% - 2px) 99%, 78% 98.7%, 55% 100%, 31% 98.8%, 2px 100%);
    transform: scaleX(1);
    box-shadow:
      inset 16px 0 18px -8px rgba(99, 71, 40, 0.06),
      inset -16px 0 18px -8px rgba(99, 71, 40, 0.055),
      inset 0 7px 11px rgba(255,255,255,0.14),
      inset 0 -7px 12px rgba(95, 71, 45, 0.05);
  }

  .scroll-paper::before,
  .scroll-paper::after {
    content: "";
    position: absolute;
    top: 2px;
    bottom: 2px;
    z-index: 2;
    width: 30px;
    pointer-events: none;
    opacity: 0.94;
    transition: transform var(--scroll-motion), opacity var(--scroll-motion), box-shadow var(--scroll-motion);
  }

  .scroll-paper::before {
    left: 0;
    transform-origin: left center;
    background:
      repeating-linear-gradient(90deg, transparent 0 7px, rgba(96, 70, 42, 0.05) 7px 8px),
      linear-gradient(90deg, rgba(72, 52, 32, 0.26), rgba(214, 197, 170, 0.95) 18%, rgba(255, 251, 240, 0.95) 38%, rgba(238, 226, 203, 0.9) 55%, rgba(148, 113, 71, 0.2) 76%, rgba(148, 113, 71, 0.06) 88%, transparent);
    border-radius: 42% 20% 20% 42% / 4% 4% 96% 96%;
    box-shadow: inset 6px 0 8px -2px rgba(80, 58, 35, 0.16), inset -4px 0 6px -2px rgba(255, 252, 244, 0.35), 6px 0 10px -2px rgba(86, 61, 36, 0.1);
  }

  .scroll-paper::after {
    right: 0;
    transform-origin: right center;
    background:
      repeating-linear-gradient(90deg, transparent 0 7px, rgba(96, 70, 42, 0.05) 7px 8px),
      linear-gradient(270deg, rgba(72, 52, 32, 0.26), rgba(214, 197, 170, 0.95) 18%, rgba(255, 251, 240, 0.95) 38%, rgba(238, 226, 203, 0.9) 55%, rgba(148, 113, 71, 0.2) 76%, rgba(148, 113, 71, 0.06) 88%, transparent);
    border-radius: 20% 42% 42% 20% / 4% 4% 96% 96%;
    box-shadow: inset -6px 0 8px -2px rgba(80, 58, 35, 0.16), inset 4px 0 6px -2px rgba(255, 252, 244, 0.35), -6px 0 10px -2px rgba(86, 61, 36, 0.1);
  }

  .article-scroll:hover .scroll-paper::before,
  .article-scroll:focus-within .scroll-paper::before,
  .article-scroll:hover .scroll-paper::after,
  .article-scroll:focus-within .scroll-paper::after {
    transform: scaleX(0.66);
    opacity: 0.76;
    box-shadow: inset 3px 0 5px rgba(102, 72, 41, 0.08);
  }

  .scroll-paper > *:not(.scroll-ink) {
    position: relative;
    z-index: 3;
  }

  .scroll-ink {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0.42;
  }

  .scroll-ink svg {
    width: 100%;
    height: 100%;
  }

  .scroll-seal {
    position: absolute !important;
    right: 15px;
    top: 11px;
    width: 26px;
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    color: rgba(249, 237, 226, 0.94);
    background: rgba(154, 65, 52, 0.78);
    border: 1px solid rgba(127, 48, 38, 0.5);
    font-family: var(--serif);
    font-size: 0.54rem;
    line-height: 1.2;
    text-align: center;
    clip-path: polygon(4% 2%, 96% 0, 100% 94%, 92% 100%, 3% 96%, 0 8%);
    transform: rotate(-2deg);
    mix-blend-mode: multiply;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.08);
  }

  .post-meta {
    grid-row: 1 / span 2;
    align-self: stretch;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2px;
    padding-right: 15px;
    color: var(--ink-soft);
    font-size: 0.72rem;
  }

  .post-meta::after {
    content: "";
    position: absolute;
    top: 2px;
    right: 0;
    bottom: 2px;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(79, 59, 40, 0.16) 18%, rgba(79, 59, 40, 0.16) 82%, transparent);
  }

  .post-meta::before {
    content: attr(data-index);
    display: block;
    margin-bottom: 2px;
    color: var(--cinnabar);
    font-family: var(--serif);
    font-size: 0.92rem;
    letter-spacing: 0.16em;
  }

  .post-meta time {
    font-family: var(--serif);
    letter-spacing: 0.04em;
  }

  .post-meta .category {
    margin-top: 3px;
    color: var(--moss-deep);
    font-family: var(--serif);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
  }

  .reading-time {
    color: var(--ink-faint);
  }

  .post-main {
    min-width: 0;
    padding-right: 30px;
    opacity: 0.92;
    transform: translateY(2px);
    transition: opacity var(--scroll-motion), transform var(--scroll-motion);
  }

  .post-title {
    margin: 0;
    font-family: var(--serif);
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    font-size: clamp(1.48rem, 2vw, 1.75rem);
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: 0.045em;
    text-wrap: balance;
  }

  .post-title a {
    background-image: linear-gradient(var(--cinnabar), var(--cinnabar));
    background-repeat: no-repeat;
    background-position: left 100%;
    background-size: 0 1px;
    transition: color var(--scroll-motion), background-size var(--scroll-motion);
  }

  .article-scroll:hover .post-title a,
  .article-scroll:focus-within .post-title a {
    color: #1f2420;
    background-size: 100% 1px;
  }

  .post-excerpt {
    max-width: 650px;
    margin: 10px 0 0;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    color: var(--ink-soft);
    font-family: var(--serif);
    font-size: 0.84rem;
    line-height: 1.6;
  }

  .post-tags {
    grid-column: 2;
    align-self: start;
    display: flex;
    flex-wrap: nowrap;
    gap: 0 10px;
    min-width: 0;
    overflow: hidden;
    white-space: nowrap;
    color: var(--ink-soft);
    font-family: var(--serif);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    opacity: 0.92;
    transform: translateY(2px);
    transition: opacity var(--scroll-motion), transform var(--scroll-motion);
  }

  .post-tags::before {
    content: "题签";
    flex: 0 0 auto;
    margin-right: 4px;
    color: var(--cinnabar);
    font-size: 0.64rem;
    letter-spacing: 0.18em;
  }

  .article-scroll:hover .post-main,
  .article-scroll:hover .post-tags,
  .article-scroll:focus-within .post-main,
  .article-scroll:focus-within .post-tags {
    opacity: 1;
    transform: translateY(0);
  }

  .post-tags span::before {
    content: "「";
    color: rgba(164, 68, 52, 0.62);
  }

  .post-tags span::after {
    content: "」";
    color: rgba(164, 68, 52, 0.62);
  }

  /* ≥821px：home-layout 双栏语境下的卡片微调（选择器与抽取前一致） */
  @media (min-width: 821px) {
    :global(.home-layout) :global(.latest) .article-scroll,
    :global(.home-layout) :global(.latest) .article-scroll:nth-child(2),
    :global(.home-layout) :global(.latest) .article-scroll:nth-child(3) {
      margin-inline: 0;
    }

    :global(.home-layout) :global(.latest) .scroll-paper {
      grid-template-columns: 92px minmax(0, 1fr);
      gap: 6px 18px;
      padding: 20px 26px 16px;
    }

    :global(.home-layout) :global(.latest) .post-tags {
      grid-column: 2;
      justify-content: flex-start;
    }

    :global(.home-layout) :global(.latest) .post-tags::before {
      width: auto;
    }
  }

  @media (max-width: 820px) {
    .article-scroll,
    .article-scroll:nth-child(2),
    .article-scroll:nth-child(3) {
      margin-inline: 0;
    }

    .scroll-paper {
      grid-template-columns: 96px minmax(0, 1fr);
      gap: 6px 18px;
      padding: 20px 26px 16px;
    }

    .post-tags {
      grid-column: 2;
      justify-content: flex-start;
    }

    .post-tags::before {
      width: auto;
    }
  }

  @media (max-width: 620px) {
    .article-scroll {
      grid-template-columns: 10px minmax(0, 1fr) 10px;
      height: auto;
      min-height: 0;
    }

    .scroll-axis {
      margin: -3px 0;
      transform: none;
    }

    .scroll-axis:last-child {
      transform: none;
    }

    .scroll-axis::before,
    .scroll-axis::after {
      width: 16px;
      height: 6px;
    }

    .scroll-axis::before { top: -3px; }
    .scroll-axis::after { bottom: -3px; }

    .scroll-paper {
      height: auto;
      grid-template-columns: 1fr;
      gap: 14px;
      padding: 38px 20px 24px;
      clip-path: polygon(2px 1%, 18% 0, 41% 1.1%, 64% 0.2%, 84% 1.2%, calc(100% - 2px) 0.5%, calc(100% - 2px) 99%, 78% 98.7%, 55% 100%, 31% 98.8%, 2px 100%);
      transform: none;
    }

    .scroll-paper::before,
    .scroll-paper::after {
      top: 2px;
      bottom: 2px;
      width: 20px;
    }

    .scroll-seal {
      right: 14px;
      top: 12px;
      width: 25px;
      font-size: 0.52rem;
    }

    .post-meta {
      grid-row: auto;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto auto;
      gap: 4px 8px;
      padding: 0 0 12px;
    }

    .post-meta::after {
      top: auto;
      left: 0;
      right: 0;
      bottom: 0;
      width: auto;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(79, 59, 40, 0.16) 14%, rgba(79, 59, 40, 0.16) 86%, transparent);
    }

    .post-meta::before {
      grid-column: 1 / -1;
      margin-bottom: 0;
    }

    .post-meta .category {
      margin-top: 0;
    }

    .reading-time {
      text-align: right;
    }

    .post-main {
      padding-right: 0;
      opacity: 1;
      transform: none;
    }

    .post-title {
      font-size: clamp(1.45rem, 7vw, 1.85rem);
    }

    .post-excerpt {
      margin-top: 10px;
      font-size: 0.88rem;
      line-height: 1.7;
    }

    .post-tags {
      grid-column: 1;
      gap: 0 8px;
      justify-content: flex-start;
      font-size: 0.74rem;
      opacity: 1;
      transform: none;
    }

    .post-tags::before {
      margin: 0 4px 0 0;
    }
  }

  /* 触屏无 hover：默认展开为静态手卷 */
  @media (hover: none) {
    .article-scroll .scroll-axis,
    .article-scroll .scroll-axis:last-child {
      transform: none;
    }

    .article-scroll .scroll-paper {
      clip-path: polygon(2px 1%, 18% 0, 41% 1.1%, 64% 0.2%, 84% 1.2%, calc(100% - 2px) 0.5%, calc(100% - 2px) 99%, 78% 98.7%, 55% 100%, 31% 98.8%, 2px 100%);
      transform: none;
    }

    .article-scroll .scroll-paper::before,
    .article-scroll .scroll-paper::after {
      transform: scaleX(0.66);
      opacity: 0.76;
    }

    .article-scroll .post-main,
    .article-scroll .post-tags {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .article-scroll,
    .article-scroll .scroll-axis,
    .article-scroll .scroll-paper,
    .article-scroll .scroll-paper::before,
    .article-scroll .scroll-paper::after,
    .article-scroll .post-main,
    .article-scroll .post-tags,
    .article-scroll .post-title a {
      transition: none;
    }

    .article-scroll .scroll-axis,
    .article-scroll .scroll-axis:last-child {
      transform: none;
    }

    .article-scroll .scroll-paper {
      clip-path: polygon(2px 1%, 18% 0, 41% 1.1%, 64% 0.2%, 84% 1.2%, calc(100% - 2px) 0.5%, calc(100% - 2px) 99%, 78% 98.7%, 55% 100%, 31% 98.8%, 2px 100%);
      transform: none;
    }

    .article-scroll .scroll-paper::before,
    .article-scroll .scroll-paper::after {
      transform: scaleX(0.66);
      opacity: 0.76;
    }

    .article-scroll .post-main,
    .article-scroll .post-tags {
      opacity: 1;
      transform: none;
    }
  }
</style>
