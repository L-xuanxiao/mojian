---
import { Image, getImage } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { formatDate, getExcerpt } from '../lib/posts';

interface Props {
  post: CollectionEntry<'blog'>;
  newerPost?: CollectionEntry<'blog'>;
  olderPost?: CollectionEntry<'blog'>;
  /** render() 产出的 remarkPluginFrontmatter（含插件注入的 excerpt/words/minutes） */
  frontmatter?: Record<string, unknown>;
}

const { post, newerPost, olderPost, frontmatter } = Astro.props;
const BASE = import.meta.env.BASE_URL;

const description = getExcerpt(post, frontmatter);
const words = Number(frontmatter?.words) || 0;
const minutes = Number(frontmatter?.minutes) || 0;

// 题图模糊占位：16px 缩略图作背景，大图加载完成后淡入
const lqip = post.data.cover
  ? await getImage({ src: post.data.cover, width: 16, format: 'webp', quality: 30 })
  : null;
---

<BaseLayout title={post.data.title} description={description || undefined}>
  <article class="article-page page-shell">
    <header class="article-header rise-in">
      <p class="meta page-kicker">
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        <span>{post.data.category}</span>
        {words > 0 && <span>凡 {words} 言</span>}
        {minutes > 0 && <span>读之 {minutes} 分钟</span>}
      </p>
      <div class="title-row">
        <h1 class="page-display-title">{post.data.title}</h1>
        <span class="seal" aria-hidden="true">墨<br />记</span>
      </div>
      {description && <p class="description">{description}</p>}
    </header>

    {post.data.cover && lqip && (
      <figure class="article-cover" style={`background-image: url(${lqip.src}); background-size: cover;`}>
        <Image
          src={post.data.cover}
          alt={`${post.data.title}题图`}
          format="webp"
          quality={84}
        />
        <figcaption>行到水穷处，坐看云起时。</figcaption>
      </figure>
    )}

    <div class="prose-ink">
      <slot />
    </div>

    <a class="back-link" href={`${BASE}#articles`}>返回笺录</a>

    {(newerPost || olderPost) && (
      <nav class="post-nav" aria-label="文章翻页">
        <div>
          {olderPost && (
            <a href={`${BASE}posts/${olderPost.id}/`}>
              <small>上一篇</small>
              <span>{olderPost.data.title}</span>
            </a>
          )}
        </div>
        <div>
          {newerPost && (
            <a href={`${BASE}posts/${newerPost.id}/`}>
              <small>下一篇</small>
              <span>{newerPost.data.title}</span>
            </a>
          )}
        </div>
      </nav>
    )}
  </article>
</BaseLayout>

<style>
  .article-page {
    position: relative;
    padding-top: clamp(4rem, 9vw, 8rem);
  }

  .article-page::before {
    position: absolute;
    top: 2.5rem;
    bottom: 0;
    left: 0.8rem;
    width: 4px;
    content: '';
    border-left: 1px solid rgb(83 79 70 / 35%);
    border-right: 1px solid rgb(83 79 70 / 16%);
  }

  .article-header {
    width: min(100%, 48rem);
    margin-inline: auto;
    text-align: center;
  }

  .meta {
    margin-bottom: 1.2rem;
    color: var(--cinnabar);
    font-size: 0.9rem;
    letter-spacing: 0.12em;
  }

  .meta span::before {
    margin-inline: 0.8rem;
    content: '·';
  }

  .title-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.4rem;
  }

  .page-display-title {
    font-size: clamp(2.6rem, 7vw, 5.2rem);
    letter-spacing: 0.12em;
  }

  .seal {
    display: grid;
    width: 2.8rem;
    height: 2.8rem;
    place-items: center;
    flex: 0 0 auto;
    border: 2px solid var(--cinnabar);
    color: var(--cinnabar);
    font-size: 0.75rem;
    line-height: 1.05;
    transform: rotate(2deg);
  }

  .description {
    margin: 1.8rem 0 0;
    color: var(--ink-soft);
    font-family: var(--serif);
    font-size: 1.08rem;
    letter-spacing: 0.08em;
    line-height: 1.8;
  }

  .article-cover {
    position: relative;
    width: min(100% - 3rem, 58rem);
    margin: clamp(3.5rem, 8vw, 6rem) auto;
    padding: clamp(0.65rem, 2vw, 1.2rem);
    border: 1px solid var(--line-strong);
    background: rgb(251 249 243 / 50%);
    box-shadow: 0 14px 30px var(--shadow);
  }

  .article-cover :global(img) {
    width: 100%;
    max-height: 35rem;
    object-fit: cover;
    filter: saturate(0.72) contrast(0.94);
    opacity: 1;
  }

  /* LQIP 淡入仅 JS 可用时启用；无 JS 时大图直接可见（见 BaseLayout 持久脚本） */
  :global(.js) .article-cover :global(img) {
    opacity: 0;
    transition: opacity 480ms ease;
  }

  :global(.js) .article-cover :global(img.is-loaded) {
    opacity: 1;
  }

  figcaption {
    position: absolute;
    top: 50%;
    left: -2.7rem;
    color: var(--moss);
    font-size: 0.86rem;
    letter-spacing: 0.18em;
    writing-mode: vertical-rl;
    transform: translateY(-50%);
  }

  .back-link {
    display: block;
    width: max-content;
    margin: 4.5rem auto 0;
    color: var(--moss-deep);
    font-family: var(--serif);
    letter-spacing: 0.12em;
  }

  .post-nav {
    display: grid;
    width: min(100%, 52rem);
    grid-template-columns: 1fr 1fr;
    margin: 4rem auto 0;
    border-top: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line-strong);
  }

  .post-nav > div {
    min-height: 7rem;
    padding: 1.5rem 2rem;
  }

  .post-nav > div + div {
    border-left: 1px solid var(--line-strong);
    text-align: right;
  }

  .post-nav a {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    text-decoration: none;
  }

  .post-nav small {
    color: var(--ink-faint);
    letter-spacing: 0.14em;
  }

  .post-nav span {
    font-size: 1.12rem;
    letter-spacing: 0.08em;
  }

  @media (max-width: 720px) {
    .article-page::before,
    figcaption {
      display: none;
    }

    .article-cover {
      width: 100%;
    }

    .post-nav {
      grid-template-columns: 1fr;
    }

    .post-nav > div + div {
      border-top: 1px solid var(--line-strong);
      border-left: 0;
    }
  }
</style>
