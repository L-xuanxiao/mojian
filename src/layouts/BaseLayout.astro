---
import InkEffects from '../components/layout/InkEffects.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';
import SiteHeader from '../components/layout/SiteHeader.astro';
import { siteConfig } from '../config/siteConfig';
import '../styles/global.css';
import '../styles/typography.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = siteConfig.name,
  description = siteConfig.description,
} = Astro.props;

const pageTitle = title === siteConfig.name ? title : `${title}${siteConfig.titleSeparator}${siteConfig.name}`;
const BASE = import.meta.env.BASE_URL;
const isHome = Astro.url.pathname === BASE;
const documentTitle = isHome && title === siteConfig.name ? siteConfig.homeTitle : pageTitle;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      // JS 可用标记 + 昼夜主题恢复（首绘前执行，防夜色闪烁与内容隐藏）
      document.documentElement.classList.add('js');
      try {
        const t = localStorage.getItem('mj-theme');
        if (t === 'night' || t === 'day') document.documentElement.dataset.theme = t;
      } catch {}
    </script>
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#eee5d2" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${BASE}favicon.svg`} />
    {
      import.meta.env.DEV
        ? <link rel="stylesheet" href={`${BASE}__fonts/fonts.css`} />
        : <meta name="mojian-fonts" content="pending" />
    }
    <title>{documentTitle}</title>
  </head>
  <body class:list={{ 'home-page': isHome, 'inner-page': !isHome }} data-base={BASE} data-font-role="serif">
    {/* 首载动画：仅完整加载出现一次，Swup 换页不重现；无 JS 时 CSS 隐藏 */}
    <div id="loader" aria-hidden="true">
      <div class="load-mark">
        <div class="load-txt" data-font-role="cal">
          {[...siteConfig.name].map((ch) => <span>{ch}</span>)}
        </div>
        <p class="load-sub" data-font-role="hand">{siteConfig.description}</p>
      </div>
    </div>

    <InkEffects />
    <div class="scroll-progress" aria-hidden="true"><i id="scrollBar"></i></div>

    <a class="skip-link" href="#main-content">跳到正文</a>
    <SiteHeader />
    <style>
      /* Swup 换页淡入淡出（reduced-motion 由全局规则压平） */
      .transition-swup-fade {
        transition: opacity 220ms ease;
        opacity: 1;
      }

      html.is-animating .transition-swup-fade {
        opacity: 0;
      }

      /* ============ 首载动画 ============ */
      #loader {
        position: fixed;
        z-index: 2000;
        inset: 0;
        display: none;
        place-items: center;
        background: var(--paper);
        transition: opacity 0.7s ease, visibility 0.7s;
      }

      :global(.js) #loader {
        display: grid;
      }

      #loader.done {
        visibility: hidden;
        opacity: 0;
      }

      .load-mark {
        position: relative;
        display: grid;
        place-items: center;
        gap: 18px;
      }

      .load-mark::before {
        position: absolute;
        width: 190px;
        aspect-ratio: 1;
        border-radius: 50%;
        content: '';
        background: radial-gradient(circle, rgb(38 36 31 / 10%), transparent 70%);
        animation: inkBloom 1.3s ease-out forwards;
      }

      :global(html[data-theme='night']) .load-mark::before {
        background: radial-gradient(circle, rgb(233 226 208 / 12%), transparent 70%);
      }

      @keyframes inkBloom {
        from {
          opacity: 0;
          transform: scale(0.1);
        }
        to {
          opacity: 1;
          transform: scale(1.4);
        }
      }

      .load-txt {
        display: flex;
        gap: 0.1em;
        color: var(--ink);
        font-size: 3rem;
        letter-spacing: 0.3em;
      }

      .load-txt span {
        opacity: 0;
        animation: chIn 0.5s forwards;
      }

      .load-txt span:nth-child(1) {
        animation-delay: 0.25s;
      }

      .load-txt span:nth-child(2) {
        animation-delay: 0.5s;
      }

      .load-sub {
        margin: 0;
        color: var(--ink-faint);
        font-size: 0.95rem;
        letter-spacing: 0.3em;
        opacity: 0;
        animation: chIn 0.6s 0.75s forwards;
      }

      @keyframes chIn {
        from {
          opacity: 0;
          transform: translateY(14px);
        }
        to {
          opacity: 1;
          transform: none;
        }
      }

      /* ============ 顶部阅读进度 ============ */
      .scroll-progress {
        position: fixed;
        z-index: 40;
        top: 0;
        right: 0;
        left: 0;
        height: 3px;
        pointer-events: none;
      }

      .scroll-progress i {
        display: block;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, var(--cinnabar), var(--bronze, #8b7355));
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.1s linear;
      }

      /* ============ 回到顶部 ============ */
      .to-top {
        position: fixed;
        z-index: 40;
        right: 22px;
        bottom: 26px;
        display: grid;
        width: 46px;
        height: 46px;
        padding: 0;
        place-items: center;
        border: 1px solid var(--line-strong);
        border-radius: 50%;
        color: var(--cinnabar);
        background: var(--paper-light);
        box-shadow: 0 8px 20px -10px var(--shadow);
        cursor: pointer;
        font-size: 1.2rem;
        line-height: 1;
        opacity: 0;
        pointer-events: none;
        transform: translateY(16px);
        transition: opacity 0.35s ease, transform 0.35s var(--ease), background 0.3s ease, color 0.3s ease;
      }

      .to-top.show {
        opacity: 1;
        pointer-events: auto;
        transform: none;
      }

      .to-top:hover {
        color: var(--paper-light);
        background: var(--cinnabar);
      }

    </style>
    <main id="main-content" class="transition-swup-fade" data-pagefind-body>
      <slot />
    </main>
    <SiteFooter />
    <button id="toTop" class="to-top" aria-label="回到顶部" type="button" data-font-role="cal">顶</button>
    <script is:inline data-swup-ignore-script>
      // 本脚本为全站持久逻辑，只执行一次；data-swup-ignore-script 阻止 Swup ScriptsPlugin
      // 换页时重放（重放会导致监听器重复注册、顶层声明冲突）。
      // 滚动显现：首页 .reveal 元素进入视口后淡入。
      // 换页后在 swup:page:view 上重放；系统关闭动画或无 IntersectionObserver 时直接显示。
      function initReveal() {
        const revealItems = document.querySelectorAll('.reveal:not(.is-visible)');
        if (revealItems.length === 0) return;
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        if (reduceMotion || !('IntersectionObserver' in window)) {
          revealItems.forEach((item) => item.classList.add('is-visible'));
        } else {
          const observer = new IntersectionObserver(
            (entries, currentObserver) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  currentObserver.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.12, rootMargin: '0px 0px -7% 0px' }
          );

          revealItems.forEach((item) => observer.observe(item));
        }
      }

      initReveal();

      // 文章题图：JS 下默认透明，加载完成（或缓存命中）后淡入。
      // 与 reveal 同理，在 swup:page:view 上重放以覆盖换页进入的文章页。
      function initCovers() {
        document.querySelectorAll('.article-cover img:not(.is-loaded)').forEach((img) => {
          if (img.dataset.coverBound) return;
          img.dataset.coverBound = '1';
          if (img.complete && img.naturalWidth > 0) {
            img.classList.add('is-loaded');
          } else {
            img.addEventListener('load', () => img.classList.add('is-loaded'), { once: true });
          }
        });
      }

      initCovers();

      // 寻墨页：pagefind-ui.js 只在整页加载时执行一次，但 PagefindUI 全局会留在内存。
      // Swup 后退/换页回到搜索页时容器内的初始化脚本不会重跑，故在此兜底重建。
      function initSearch() {
        const el = document.getElementById('search');
        if (el && typeof PagefindUI !== 'undefined' && !el.dataset.pagefindReady) {
          el.dataset.pagefindReady = '1';
          new PagefindUI({
            element: '#search',
            bundlePath: `${document.body.dataset.base}pagefind/`,
            showSubResults: true,
            showImages: false,
          });
        }
      }

      initSearch();

      // 首载动画：完整加载且最短停留后淡出并移除节点；2.6s 兜底强制移除。
      // body.loaded 供首页 hero 入场动画接力。
      (function () {
        const loader = document.getElementById('loader');
        if (!loader) {
          document.body.classList.add('loaded');
          return;
        }
        const start = performance.now();
        let finished = false;
        const finish = () => {
          if (finished) return;
          finished = true;
          const wait = Math.max(0, 900 - (performance.now() - start));
          setTimeout(() => {
            loader.classList.add('done');
            document.body.classList.add('loaded');
            setTimeout(() => loader.remove(), 800);
          }, wait);
        };
        const pageReady = document.readyState === 'complete'
          ? Promise.resolve()
          : new Promise((resolve) => window.addEventListener('load', resolve, { once: true }));
        const fontsReady = document.fonts?.load
          ? Promise.all([
              document.fonts.load('400 1em "Noto Serif SC"', '墨笺正文'),
              document.fonts.load('400 1em "Ma Shan Zheng"', '墨笺'),
            ]).catch(() => undefined)
          : Promise.resolve();
        Promise.all([pageReady, fontsReady]).then(finish);
        setTimeout(finish, 2600);
      })();

      // 昼夜切换：事件委托（按钮位于 Swup 交换的 header 内，委托到 document 不丢绑定）
      // 支持 View Transitions 时新主题从按钮中心圆形扩散；reduced-motion 或不支持时回退瞬时切换
      const applyTheme = (next) => {
        document.documentElement.dataset.theme = next;
        try {
          localStorage.setItem('mj-theme', next);
        } catch {}
      };
      // 扩散期间经 html.theme-vt 关闭 body 颜色淡化（否则新状态快照每帧整页重栅格，卡顿且边界被洗没）。
      // 计数器防快速连点：上一次 VT 被 skip 时其 finished 也会结算，depth 归零才摘门闩。
      let themeVtDepth = 0;
      document.addEventListener('click', (event) => {
        const btn = event.target && event.target.closest ? event.target.closest('[data-theme-toggle]') : null;
        if (!btn) return;
        const next = document.documentElement.dataset.theme === 'night' ? 'day' : 'night';
        if (typeof document.startViewTransition !== 'function' || matchMedia('(prefers-reduced-motion: reduce)').matches) {
          applyTheme(next);
          return;
        }
        // 终止进行中的平滑/惯性滚动：VT 捕获发生在滚动停止后，若点击时页面还在动，
        // 捕获滚动位置会晚于测量值 S2-S1，圆心相对按钮上偏这么多
        window.scrollTo({ top: scrollY, left: scrollX, behavior: 'instant' });
        // 圆心取按钮中心的文档坐标百分比：root 捕获盒是整个文档而非视口，clip 坐标按文档
        // 空间解释且不补偿滚动；百分比与盒子缩放（CSS px / 设备 px）无关，圆心才能钉在按钮上
        const rect = btn.getBoundingClientRect();
        const docW = document.documentElement.scrollWidth;
        const docH = document.documentElement.scrollHeight;
        const docX = rect.left + rect.width / 2 + scrollX;
        const docY = rect.top + rect.height / 2 + scrollY;
        // 半径用 vmax 视口单位：clip circle 的 % 半径按伪元素参考盒对角线解析（实测远小于
        // 预期，圆铺不满 → 过渡结束伪元素移除时未覆盖区域瞬间跳变 = "后段突然加速"）；
        // vmax 恒为视口 CSS 像素，与参考盒解释无关，任何环境都恰好铺满
        const radiusVmax = (Math.hypot(Math.max(rect.left + rect.width / 2, innerWidth - rect.left - rect.width / 2), Math.max(rect.top + rect.height / 2, innerHeight - rect.top - rect.height / 2)) / (Math.max(innerWidth, innerHeight) / 100)) * 1.03;
        const at = `${(docX / docW) * 100}% ${(docY / docH) * 100}%`;
        themeVtDepth++;
        document.documentElement.classList.add('theme-vt');
        const vt = document.startViewTransition(() => applyTheme(next));
        // finished/ready 在过渡被 skip（快速连点）时 reject，两条链都必须吞掉 AbortError，否则控制台报未处理拒绝
        const release = () => {
          if (--themeVtDepth === 0) document.documentElement.classList.remove('theme-vt');
        };
        vt.finished.then(release, release);
        vt.ready.then(() => {
          document.documentElement.animate(
            { clipPath: [`circle(0px at ${at})`, `circle(${radiusVmax}vmax at ${at})`] },
            // 半径匀速扩散：ease-in-out 的中段加速会被感知为“中途突然加速”
            { duration: 600, easing: 'linear', pseudoElement: '::view-transition-new(root)' }
          );
        }, () => {});
      });

      // 顶部进度条 + 回到顶部（window 监听，Swup 换页后仍有效）
      (function () {
        const bar = document.getElementById('scrollBar');
        const toTop = document.getElementById('toTop');
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const onScroll = () => {
          const range = document.documentElement.scrollHeight - window.innerHeight;
          const progress = range > 0 ? window.scrollY / range : 0;
          if (bar) bar.style.transform = 'scaleX(' + progress + ')';
          if (toTop) toTop.classList.toggle('show', window.scrollY > 600);
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
        document.addEventListener('swup:page:view', onScroll);
        if (toTop) {
          toTop.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: reduceMotion ? 'auto' : 'smooth' });
          });
        }
      })();

      // 留墨表单：document 级 submit 委托（盖印 → mailto 草稿），
      // 委托挂 document 使 Swup 缓存恢复留墨页后仍然生效。
      document.addEventListener('submit', (event) => {
        const form = event.target && event.target.closest ? event.target.closest('#inkForm') : null;
        if (!form) return;
        event.preventDefault();
        const email = form.dataset.email || '';
        const whoField = form.querySelector('[name="who"]');
        const msgField = form.querySelector('[name="msg"]');
        const who = whoField && whoField.value ? whoField.value.trim() : '';
        const msg = msgField && msgField.value ? msgField.value.trim() : '';
        if (!who || !msg) return;
        const subject = encodeURIComponent('【墨笺留墨】' + who);
        const body = encodeURIComponent(msg + '\n\n—— ' + who);
        const toast = document.getElementById('inkToast');
        form.classList.remove('stamped');
        void form.offsetWidth;
        form.classList.add('stamped');
        if (toast) {
          toast.textContent = '书信已备好，交由你的信使递出。';
          toast.classList.add('show');
          setTimeout(() => toast.classList.remove('show'), 2600);
        }
        setTimeout(() => {
          window.location.href = 'mailto:' + email + '?subject=' + subject + '&body=' + body;
        }, 650);
        setTimeout(() => {
          form.reset();
          form.classList.remove('stamped');
        }, 1800);
      });

      document.addEventListener('swup:page:view', () => {
        initReveal();
        initCovers();
        initSearch();
      });
    </script>
  </body>
</html>
